GCP_PROJECT_ID=your-project-id
GCP_BUCKET_NAME=your-bucket-name
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json

# Override if your project has a different Vertex AI model version enabled
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# NVIDIA NAT API — required for Node 2 (PyTorch scaffold) and Node 3 (CUDA blueprint)
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=your-nvidia-api-key
NAT_MODEL_CODE=qwen/qwen2.5-coder-32b-instruct
NAT_MODEL_REASON=nvidia/llama-3.1-nemotron-ultra-253b-v1
# NAT_TIMEOUT=120
